[Unit]
Description=HackerOS Hacker Mode UI
After=hackeros-hm-compositor.service
Requires=hackeros-hm-compositor.service

[Service]
Type=simple
ExecStart=/usr/local/bin/hm-ui
Restart=on-failure
RestartSec=2
Environment=XDG_RUNTIME_DIR=/run/user/%U
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/%U/bus

[Install]
WantedBy=graphical-session.target
