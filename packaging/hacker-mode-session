#!/usr/bin/env bash
# Skrypt startowy sesji Wayland dla SDDM. Ten plik jest wskazywany przez
# /usr/share/wayland-sessions/hacker-mode.desktop (pole Exec). SDDM uruchamia
# go bezpośrednio na TTY, po czym `hacker-mode default` przejmuje ekran
# jako samodzielny kompozytor (Smithay, DRM/udev) — patrz src/compositor/.
set -euo pipefail

export XDG_CURRENT_DESKTOP=Hacker-Mode
export XDG_SESSION_TYPE=wayland

exec /usr/bin/hacker-mode default
