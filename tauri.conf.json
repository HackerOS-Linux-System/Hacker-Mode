{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hacker Mode",
  "version": "0.1.0",
  "identifier": "mode.hacker.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui",
    "beforeBuildCommand": "npm run build --prefix ui",
    "devUrl": "http://localhost:5173",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hacker Mode",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "width": 1280,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
