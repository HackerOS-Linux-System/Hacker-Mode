{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hacker Mode",
  "version": "1.0.0",
  "identifier": "com.hackermode.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hacker Mode",
        "width": 1280,
        "height": 800,
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Game",
    "shortDescription": "Hacker Mode Launcher",
    "longDescription": "",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
