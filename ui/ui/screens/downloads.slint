import { HMTheme } from "../theme.slint";

export struct DownloadItem {
    id: string,
    title: string,
    source: string,
    source-color: color,
    progress: float,    // 0.0–1.0
    speed-mb: float,
    size-gb: float,
    status: string,     // "downloading"|"paused"|"queued"|"done"|"error"
}

export component DownloadsScreen inherits Rectangle {
    background: HMTheme.bg-primary;
    horizontal-stretch: 1;

    in property <[DownloadItem]> downloads;

    callback pause(string);
    callback resume(string);
    callback cancel(string);

    VerticalLayout {
        padding: HMTheme.space-lg;
        spacing: HMTheme.space-lg;

        // Header
        HorizontalLayout {
            Text {
                text: "DOWNLOADS";
                color: HMTheme.text-primary;
                font-size: HMTheme.font-xl;
                font-weight: 700;
                letter-spacing: 1px;
                horizontal-stretch: 1;
            }
            Text {
                text: downloads.length + " items";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-sm;
                vertical-alignment: center;
            }
        }

        Rectangle { height: 1px; background: HMTheme.border; }

        if downloads.length == 0: VerticalLayout {
            alignment: center;
            spacing: HMTheme.space-md;
            height: 300px;

            Text {
                text: "⬇";
                color: HMTheme.text-muted;
                font-size: 48px;
                horizontal-alignment: center;
                opacity: 0.3;
            }
            Text {
                text: "No active downloads";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-lg;
                horizontal-alignment: center;
            }
            Text {
                text: "Browse the stores to find and install games.";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-sm;
                horizontal-alignment: center;
            }
        }

        Flickable {
            vertical-stretch: 1;
            viewport-height: list.preferred-height;

            list := VerticalLayout {
                spacing: HMTheme.space-sm;

                for item in downloads: DownloadRow {
                    item: item;
                    pause-clicked  => { pause(item.id); }
                    resume-clicked => { resume(item.id); }
                    cancel-clicked => { cancel(item.id); }
                }
            }
        }
    }
}

component DownloadRow inherits Rectangle {
    in property <DownloadItem> item;
    callback pause-clicked();
    callback resume-clicked();
    callback cancel-clicked();

    height: 72px;
    border-radius: HMTheme.radius-md;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: HMTheme.border;

    VerticalLayout {
        padding: HMTheme.space-md;
        spacing: HMTheme.space-sm;

        // Top row: title + actions
        HorizontalLayout {
            spacing: HMTheme.space-sm;

            // Source dot
            Rectangle {
                width: 7px; height: 7px;
                border-radius: 3.5px;
                background: item.source-color;
                y: 5px;
            }

            Text {
                text: item.title;
                color: HMTheme.text-primary;
                font-size: HMTheme.font-md;
                font-weight: 600;
                horizontal-stretch: 1;
                overflow: elide;
                vertical-alignment: center;
            }

            // Speed
            if item.status == "downloading": Text {
                text: item.speed-mb + " MB/s";
                color: HMTheme.gold;
                font-size: HMTheme.font-xs;
                font-weight: 600;
                vertical-alignment: center;
            }

            // Status badge
            Rectangle {
                height: 22px;
                width: status-text.preferred-width + 12px;
                border-radius: 11px;
                background: status-bg();

                status-text := Text {
                    text: item.status;
                    color: status-color();
                    font-size: HMTheme.font-xs;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Pause/Resume/Cancel buttons
            if item.status == "downloading": SmallBtn { icon: "⏸"; clicked => { pause-clicked(); } }
            if item.status == "paused":      SmallBtn { icon: "▶"; clicked => { resume-clicked(); } }
            SmallBtn { icon: "✕"; clicked => { cancel-clicked(); } }
        }

        // Progress bar
        Rectangle {
            height: 4px;
            border-radius: 2px;
            background: HMTheme.border;

            Rectangle {
                width: parent.width * item.progress;
                height: 4px;
                border-radius: 2px;
                background: item.status == "error"
                    ? HMTheme.error
                    : item.status == "done"
                        ? HMTheme.success
                        : @linear-gradient(90deg, HMTheme.orange, HMTheme.gold);
                animate width { duration: 300ms; }
            }
        }

        // Size + percent
        HorizontalLayout {
            Text {
                text: Math.round(item.progress * 100.0) + "%";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-xs;
                horizontal-stretch: 1;
            }
            Text {
                text: item.size-gb + " GB";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-xs;
            }
        }
    }

    pure function status-color() -> color {
        if item.status == "downloading" { return HMTheme.gold; }
        if item.status == "paused"      { return HMTheme.warning; }
        if item.status == "done"        { return HMTheme.success; }
        if item.status == "error"       { return HMTheme.error; }
        return HMTheme.text-muted;
    }

    pure function status-bg() -> color {
        if item.status == "downloading" { return rgba(245,166,35,0.12); }
        if item.status == "paused"      { return rgba(251,191,36,0.12); }
        if item.status == "done"        { return rgba(52,211,153,0.12); }
        if item.status == "error"       { return rgba(248,113,113,0.12); }
        return HMTheme.bg-secondary;
    }
}

component SmallBtn inherits Rectangle {
    in property <string> icon;
    callback clicked();
    width: 26px; height: 26px;
    border-radius: HMTheme.radius-sm;
    background: transparent;
    states [ hover when ta.has-hover: { background: HMTheme.bg-overlay; } ]
    animate background { duration: HMTheme.anim-fast; }
    Text { text: icon; color: HMTheme.text-muted; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    ta := TouchArea { clicked => { clicked(); } }
}
