import { HMTheme } from "../theme.slint";
import { GameCard, GameCardData } from "../components/game_card.slint";

export struct HeroData {
    game-id: string,
    title: string,
    developer: string,
    year: string,
    genres: [string],
    store-label: string,
    hero-path: string,
    cover-path: string,
    proton-label: string,
    proton-ok: bool,
    is-running: bool,
    playtime-h: int,
}

export component LibraryScreen inherits Rectangle {
    background: HMTheme.bg-primary;

    in property <HeroData>         hero;
    in property <[GameCardData]>   recent-games;
    in property <[GameCardData]>   all-games;
    in property <string>           filter-text: "";
    in property <bool>             loading: false;

    callback play(string);
    callback open-detail(string);
    callback toggle-favourite(string);
    callback search-changed(string);
    callback see-all-recent();
    callback see-all-games();

    VerticalLayout {
        // ── Hero banner ───────────────────────────────────────────────────
        if hero.game-id != "": HeroBanner {
            hero: hero;
            play  => { play(hero.game-id); }
            detail => { open-detail(hero.game-id); }
        }

        // ── Scrollable content ────────────────────────────────────────────
        Flickable {
            vertical-stretch: 1;
            viewport-height: content-col.preferred-height;

            content-col := VerticalLayout {
                padding: HMTheme.space-lg;
                spacing: HMTheme.space-lg;

                // Search bar
                SearchBar {
                    placeholder: "Search library…";
                    value: filter-text;
                    changed(t) => { search-changed(t); }
                }

                // Recently played
                if recent-games.length > 0: GameSection {
                    title: "RECENTLY PLAYED";
                    games: recent-games;
                    play(id)             => { play(id); }
                    open-detail(id)      => { open-detail(id); }
                    toggle-favourite(id) => { toggle-favourite(id); }
                    see-all              => { see-all-recent(); }
                }

                // All games
                GameSection {
                    title: "ALL GAMES";
                    games: all-games;
                    play(id)             => { play(id); }
                    open-detail(id)      => { open-detail(id); }
                    toggle-favourite(id) => { toggle-favourite(id); }
                    see-all              => { see-all-games(); }
                }
            }
        }
    }
}

// ── Hero banner ───────────────────────────────────────────────────────────────

component HeroBanner inherits Rectangle {
    in property <HeroData> hero;
    callback play();
    callback detail();

    height: 240px;
    clip: true;
    background: @linear-gradient(135deg, #0f0e0c, #1a1612);

    // Hero image
    if hero.hero-path != "": Image {
        source: @image-url(hero.hero-path);
        image-fit: cover;
        width: 100%;
        height: 100%;
        opacity: 0.55;
    }

    // Gradient overlay
    Rectangle {
        background: @linear-gradient(90deg,
            rgba(10, 10, 8, 0.95) 0%,
            rgba(10, 10, 8, 0.60) 50%,
            rgba(232, 88, 12, 0.12) 100%);
    }

    // Radial glow
    Rectangle {
        x: parent.width * 0.6;
        y: 0px;
        width: parent.width * 0.5;
        height: parent.height;
        background: radial-gradient(rgba(232, 88, 12, 0.15), transparent);
    }

    HorizontalLayout {
        padding: HMTheme.space-lg;
        spacing: HMTheme.space-lg;
        alignment: start;

        // ── Left: meta ────────────────────────────────────────────────────
        VerticalLayout {
            alignment: end;
            spacing: HMTheme.space-sm;
            horizontal-stretch: 1;

            // Store / status label
            HorizontalLayout {
                spacing: HMTheme.space-sm;
                alignment: start;

                Rectangle {
                    width: 18px; height: 2px;
                    background: HMTheme.orange;
                    y: 6px;
                }
                Text {
                    text: hero.store-label + (hero.is-running ? " — RUNNING" : "");
                    color: HMTheme.text-muted;
                    font-size: HMTheme.font-xs;
                    font-weight: 700;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }
            }

            // Title
            Text {
                text: hero.title;
                color: HMTheme.text-primary;
                font-size: HMTheme.font-3xl;
                font-weight: 700;
                letter-spacing: -0.5px;
                wrap: no-wrap;
                overflow: elide;
            }

            // Developer + year
            Text {
                text: hero.developer + " · " + hero.year;
                color: HMTheme.text-muted;
                font-size: HMTheme.font-sm;
            }

            // Tags row
            HorizontalLayout {
                spacing: HMTheme.space-sm;
                alignment: start;

                for genre in hero.genres: Tag {
                    label: genre;
                }
                Tag {
                    label: hero.proton-label;
                    highlight: hero.proton-ok;
                }
            }

            // Playtime
            if hero.playtime-h > 0: Text {
                text: hero.playtime-h + " hours played";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-sm;
            }

            // Action buttons
            HorizontalLayout {
                spacing: HMTheme.space-sm;
                alignment: start;

                // Play button
                Rectangle {
                    height: 40px;
                    width: play-text.preferred-width + 40px;
                    border-radius: HMTheme.radius-sm;
                    background: @linear-gradient(90deg, HMTheme.orange, HMTheme.gold);

                    states [
                        hover when play-ta.has-hover: {
                            background: @linear-gradient(90deg, HMTheme.orange-dim, HMTheme.gold-dim);
                        }
                    ]

                    animate background { duration: HMTheme.anim-fast; }

                    HorizontalLayout {
                        padding-left: HMTheme.space-md;
                        padding-right: HMTheme.space-md;
                        spacing: HMTheme.space-sm;
                        alignment: center;

                        Text {
                            text: "▶";
                            color: HMTheme.bg-primary;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        play-text := Text {
                            text: hero.is-running ? "RUNNING" : "PLAY";
                            color: HMTheme.bg-primary;
                            font-size: HMTheme.font-md;
                            font-weight: 700;
                            letter-spacing: 1px;
                            vertical-alignment: center;
                        }
                    }

                    play-ta := TouchArea { clicked => { play(); } }
                }

                // Details button
                SecondaryBtn {
                    label: "Details";
                    clicked => { detail(); }
                }
            }
        }

        // ── Right: cover art ──────────────────────────────────────────────
        Rectangle {
            width: 133px;
            height: 200px;
            border-radius: HMTheme.radius-md;
            background: @linear-gradient(160deg, #2a1a0e, #1a0f06);
            border-width: 1px;
            border-color: rgba(245, 166, 35, 0.15);
            clip: true;

            if hero.cover-path != "": Image {
                source: @image-url(hero.cover-path);
                image-fit: cover;
                width: 100%;
                height: 100%;
            }
        }
    }
}

// ── Game section (title + grid) ───────────────────────────────────────────────

component GameSection inherits VerticalLayout {
    in property <string>         title;
    in property <[GameCardData]> games;
    callback play(string);
    callback open-detail(string);
    callback toggle-favourite(string);
    callback see-all();

    spacing: HMTheme.space-md;

    // Section header
    HorizontalLayout {
        Text {
            text: title;
            color: HMTheme.text-primary;
            font-size: HMTheme.font-lg;
            font-weight: 700;
            letter-spacing: 0.5px;
            horizontal-stretch: 1;
        }
        Text {
            text: "See all →";
            color: HMTheme.text-muted;
            font-size: HMTheme.font-sm;
            vertical-alignment: center;

            TouchArea {
                mouse-cursor: pointer;
                clicked => { see-all(); }
            }
        }
    }

    // 5-column grid
    HorizontalLayout {
        spacing: HMTheme.space-sm;

        for game in games: GameCard {
            game: game;
            horizontal-stretch: 1;
            play(id)             => { play(id); }
            open-detail(id)      => { open-detail(id); }
            toggle-favourite(id) => { toggle-favourite(id); }
        }
    }
}

// ── Helpers ───────────────────────────────────────────────────────────────────

component Tag inherits Rectangle {
    in property <string> label;
    in property <bool>   highlight: false;

    height: 22px;
    width: tag-text.preferred-width + 16px;
    border-radius: 4px;
    border-width: 1px;
    border-color: highlight ? rgba(52, 211, 153, 0.30) : HMTheme.border;
    background: transparent;

    tag-text := Text {
        text: label;
        color: highlight ? HMTheme.success : HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        letter-spacing: 0.3px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component SecondaryBtn inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 40px;
    width: btn-text.preferred-width + 32px;
    border-radius: HMTheme.radius-sm;
    background: transparent;
    border-width: 1px;
    border-color: HMTheme.border;

    states [
        hover when ta.has-hover: {
            border-color: rgba(245, 166, 35, 0.30);
            btn-text.color: HMTheme.text-primary;
        }
    ]
    animate border-color { duration: HMTheme.anim-fast; }

    btn-text := Text {
        text: label;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-sm;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: HMTheme.anim-fast; }
    }

    ta := TouchArea { clicked => { clicked(); } }
}

component SearchBar inherits Rectangle {
    in property <string>  placeholder;
    in-out property <string> value;
    callback changed(string);

    height: 38px;
    border-radius: HMTheme.radius-sm;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: HMTheme.border;

    states [
        focus when input.has-focus: {
            border-color: HMTheme.border-focus;
        }
    ]

    animate border-color { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: HMTheme.space-md;
        padding-right: HMTheme.space-md;
        spacing: HMTheme.space-sm;

        Text {
            text: "⌕";
            color: HMTheme.text-muted;
            font-size: 14px;
            vertical-alignment: center;
        }

        input := TextInput {
            text: value;
            color: HMTheme.text-primary;
            font-size: HMTheme.font-md;
            vertical-alignment: center;
            horizontal-stretch: 1;

            placeholder-text: placeholder;
            placeholder-color: HMTheme.text-muted;

            edited => {
                value = self.text;
                changed(self.text);
            }
        }
    }
}
