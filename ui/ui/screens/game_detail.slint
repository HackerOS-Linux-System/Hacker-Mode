import { HMTheme } from "../theme.slint";

export struct GameDetailData {
    id: string,
    title: string,
    developer: string,
    publisher: string,
    year: string,
    genres: [string],
    source: string,
    source-label: string,
    source-color: color,
    cover-image: image,
    hero-image: image,
    install-path: string,
    executable: string,
    size-gb: float,
    runner: string,
    proton-version: string,
    proton-ok: bool,
    playtime-h: int,
    playtime-m: int,
    last-played: string,
    is-installed: bool,
    is-running: bool,
    is-favourite: bool,
}

export component GameDetailScreen inherits Rectangle {
    background: HMTheme.bg-primary;
    horizontal-stretch: 1;

    in property <GameDetailData> game;

    callback play(string);
    callback kill(string);
    callback toggle-favourite(string);
    callback uninstall(string);
    callback change-runner(string);
    callback open-in-store(string);
    callback open-protondb(string);
    callback close();

    VerticalLayout {
        // ── Hero backdrop ──────────────────────────────────────────────────
        Rectangle {
            height: 220px;
            clip: true;
            background: @linear-gradient(135deg, #0f0e0c, #1a1612);

            if game.hero-image.width > 0: Image {
                source: game.hero-image;
                image-fit: cover;
                width: 100%; height: 100%;
                opacity: 0.45;
            }

            Rectangle {
                background: @linear-gradient(0deg, HMTheme.bg-primary 0%, transparent 100%);
            }

            // Back button
            Rectangle {
                x: HMTheme.space-lg;
                y: HMTheme.space-md;
                width: 80px; height: 32px;
                border-radius: HMTheme.radius-sm;
                background: rgba(10,10,8,0.70);
                border-width: 1px;
                border-color: HMTheme.border;

                HorizontalLayout {
                    spacing: 4px;
                    alignment: center;
                    Text { text: "‹"; color: HMTheme.text-muted; font-size: 16px; vertical-alignment: center; }
                    Text { text: "Back"; color: HMTheme.text-muted; font-size: HMTheme.font-sm; vertical-alignment: center; }
                }
                TouchArea { clicked => { close(); } }
            }
        }

        // ── Content ────────────────────────────────────────────────────────
        Flickable {
            vertical-stretch: 1;
            viewport-height: body.preferred-height + 40px;

            body := HorizontalLayout {
                padding: HMTheme.space-lg;
                spacing: HMTheme.space-xl;
                alignment: start;

                // ── Left: cover + actions ──────────────────────────────────
                VerticalLayout {
                    width: 200px;
                    spacing: HMTheme.space-md;
                    alignment: start;

                    // Cover art
                    Rectangle {
                        width: 200px; height: 267px;
                        border-radius: HMTheme.radius-md;
                        background: HMTheme.bg-elevated;
                        border-width: 1px;
                        border-color: HMTheme.border;
                        clip: true;

                        if game.cover-image.width > 0: Image {
                            source: game.cover-image;
                            image-fit: cover;
                            width: 100%; height: 100%;
                        }
                    }

                    // Play / Kill button
                    if !game.is-running: ActionButton {
                        label: "▶  PLAY";
                        primary: true;
                        clicked => { play(game.id); }
                    }
                    if game.is-running: ActionButton {
                        label: "⏹  RUNNING";
                        primary: false;
                        clicked => { kill(game.id); }
                    }

                    // Secondary actions
                    ActionButton { label: "★  " + (game.is-favourite ? "Unfavourite" : "Favourite"); clicked => { toggle-favourite(game.id); } }
                    ActionButton { label: "↗  View in Store"; clicked => { open-in-store(game.source); } }
                    ActionButton { label: "◉  ProtonDB"; clicked => { open-protondb(game.id); } }

                    if game.is-installed: ActionButton {
                        label: "🗑  Uninstall";
                        clicked => { uninstall(game.id); }
                    }
                }

                // ── Right: metadata ────────────────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: HMTheme.space-lg;
                    alignment: start;

                    // Title + source
                    VerticalLayout {
                        spacing: HMTheme.space-sm;

                        HorizontalLayout {
                            spacing: HMTheme.space-sm;
                            alignment: start;

                            Rectangle {
                                width: 7px; height: 7px;
                                border-radius: 3.5px;
                                background: game.source-color;
                                y: 8px;
                            }
                            Text {
                                text: game.source-label;
                                color: HMTheme.text-muted;
                                font-size: HMTheme.font-sm;
                                font-weight: 700;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: game.title;
                            color: HMTheme.text-primary;
                            font-size: HMTheme.font-3xl;
                            font-weight: 700;
                            letter-spacing: -0.5px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: game.developer + (game.publisher != "" && game.publisher != game.developer
                                ? " / " + game.publisher : "")
                                + (game.year != "" ? "  ·  " + game.year : "");
                            color: HMTheme.text-muted;
                            font-size: HMTheme.font-md;
                        }
                    }

                    // Genres
                    if game.genres.length > 0: HorizontalLayout {
                        spacing: HMTheme.space-sm;
                        alignment: start;
                        for genre in game.genres: GenreTag { label: genre; }
                    }

                    // Stats row
                    HorizontalLayout {
                        spacing: HMTheme.space-lg;
                        alignment: start;

                        StatBlock { label: "PLAYTIME"; value: game.playtime-h > 0 ? game.playtime-h + " hours" : "Not played"; }
                        StatBlock { label: "LAST PLAYED"; value: game.last-played != "" ? game.last-played : "Never"; }
                        if game.size-gb > 0.0: StatBlock { label: "SIZE"; value: Math.round(game.size-gb * 10.0) / 10.0 + " GB"; }
                    }

                    // Compatibility
                    CompatRow {
                        runner: game.runner;
                        proton-version: game.proton-version;
                        proton-ok: game.proton-ok;
                    }

                    // Install info
                    if game.install-path != "": InstallInfo {
                        install-path: game.install-path;
                        executable:   game.executable;
                    }
                }
            }
        }
    }
}

// ── Action button ─────────────────────────────────────────────────────────────

component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool>   primary: false;
    callback clicked();

    height: 40px;
    width: 200px;
    border-radius: HMTheme.radius-sm;
    background: primary
        ? @linear-gradient(90deg, HMTheme.orange, HMTheme.gold)
        : HMTheme.bg-elevated;
    border-width: primary ? 0px : 1px;
    border-color: HMTheme.border;

    states [
        hover when ta.has-hover && !primary: {
            background: HMTheme.bg-overlay;
            border-color: rgba(245,166,35,0.3);
        }
    ]
    animate background, border-color { duration: HMTheme.anim-fast; }

    Text {
        text: label;
        color: primary ? HMTheme.bg-primary : HMTheme.text-secondary;
        font-size: HMTheme.font-sm;
        font-weight: primary ? 700 : 500;
        letter-spacing: primary ? 0.5px : 0;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea { clicked => { clicked(); } }
}

// ── Genre tag ─────────────────────────────────────────────────────────────────

component GenreTag inherits Rectangle {
    in property <string> label;
    height: 24px;
    width: t.preferred-width + 16px;
    border-radius: 4px;
    border-width: 1px;
    border-color: HMTheme.border;

    t := Text {
        text: label;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ── Stat block ────────────────────────────────────────────────────────────────

component StatBlock inherits VerticalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 3px;

    Text { text: label; color: HMTheme.text-muted; font-size: HMTheme.font-xs; font-weight: 700; letter-spacing: 1px; }
    Text { text: value; color: HMTheme.text-primary; font-size: HMTheme.font-md; font-weight: 600; }
}

// ── Compat row ────────────────────────────────────────────────────────────────

component CompatRow inherits Rectangle {
    in property <string> runner;
    in property <string> proton-version;
    in property <bool>   proton-ok;

    height: 52px;
    border-radius: HMTheme.radius-sm;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: proton-ok
        ? rgba(52,211,153,0.25)
        : HMTheme.border;

    HorizontalLayout {
        padding: HMTheme.space-md;
        spacing: HMTheme.space-md;
        alignment: start;

        Text {
            text: "RUNNER";
            color: HMTheme.text-muted;
            font-size: HMTheme.font-xs;
            font-weight: 700;
            letter-spacing: 1px;
            vertical-alignment: center;
            width: 60px;
        }

        Text {
            text: proton-version != "" ? proton-version : runner;
            color: proton-ok ? HMTheme.success : HMTheme.text-secondary;
            font-size: HMTheme.font-sm;
            font-weight: 600;
            vertical-alignment: center;
        }

        if proton-ok: Text {
            text: "✓ Verified";
            color: HMTheme.success;
            font-size: HMTheme.font-xs;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

// ── Install info ──────────────────────────────────────────────────────────────

component InstallInfo inherits VerticalLayout {
    in property <string> install-path;
    in property <string> executable;
    spacing: 4px;

    Text {
        text: "INSTALL LOCATION";
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        font-weight: 700;
        letter-spacing: 1px;
    }
    Text {
        text: install-path;
        color: HMTheme.text-secondary;
        font-size: HMTheme.font-sm;
        overflow: elide;
    }
    if executable != "": Text {
        text: executable;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        overflow: elide;
    }
}
