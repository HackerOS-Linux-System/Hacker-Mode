import { HMTheme } from "../theme.slint";

export component SettingsScreen inherits Rectangle {
    background: HMTheme.bg-primary;
    horizontal-stretch: 1;

    in-out property <int>   active-section: 0;

    callback language-changed(string);
    callback theme-changed(string);
    callback proton-default-changed(string);
    callback night-mode-toggled(bool);
    callback compositor-vsync-toggled(bool);
    callback compositor-hdr-toggled(bool);
    callback compositor-adaptive-sync-toggled(bool);

    HorizontalLayout {
        // ── Section nav ───────────────────────────────────────────────────
        Rectangle {
            width: 200px;
            background: HMTheme.bg-secondary;
            border-color: HMTheme.border;
            border-right-width: 1px;

            VerticalLayout {
                padding: HMTheme.space-md;
                spacing: 2px;

                SettingsNavItem { label: "General";     icon: "⚙"; active: active-section == 0; clicked => { active-section = 0; } }
                SettingsNavItem { label: "Appearance";  icon: "🎨"; active: active-section == 1; clicked => { active-section = 1; } }
                SettingsNavItem { label: "Compositor";  icon: "⊡"; active: active-section == 2; clicked => { active-section = 2; } }
                SettingsNavItem { label: "Proton";      icon: "◉"; active: active-section == 3; clicked => { active-section = 3; } }
                SettingsNavItem { label: "Network";     icon: "📶"; active: active-section == 4; clicked => { active-section = 4; } }
                SettingsNavItem { label: "About";       icon: "ℹ"; active: active-section == 5; clicked => { active-section = 5; } }
            }
        }

        // ── Content ───────────────────────────────────────────────────────
        Flickable {
            horizontal-stretch: 1;
            viewport-height: content.preferred-height + 40px;

            content := VerticalLayout {
                padding: HMTheme.space-xl;
                spacing: HMTheme.space-lg;

                if active-section == 0: GeneralSection {
                    language-changed(l)      => { language-changed(l); }
                }
                if active-section == 1: AppearanceSection {}
                if active-section == 2: CompositorSection {
                    vsync-toggled(v)          => { compositor-vsync-toggled(v); }
                    hdr-toggled(v)            => { compositor-hdr-toggled(v); }
                    adaptive-sync-toggled(v)  => { compositor-adaptive-sync-toggled(v); }
                }
                if active-section == 3: ProtonSection {
                    default-changed(v)        => { proton-default-changed(v); }
                }
                if active-section == 5: AboutSection {}
            }
        }
    }
}

// ── Nav item ──────────────────────────────────────────────────────────────────

component SettingsNavItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool>   active: false;
    callback clicked();

    height: 38px;
    border-radius: HMTheme.radius-sm;
    background: active ? rgba(245,166,35,0.08) : transparent;

    states [
        hover when ta.has-hover && !active: { background: HMTheme.bg-elevated; }
    ]
    animate background { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: HMTheme.space-sm;
        padding-right: HMTheme.space-sm;
        spacing: HMTheme.space-sm;

        Text {
            width: 18px;
            text: icon;
            color: active ? HMTheme.gold : HMTheme.text-muted;
            font-size: 13px;
            vertical-alignment: center;
        }
        Text {
            text: label;
            color: active ? HMTheme.gold : HMTheme.text-muted;
            font-size: HMTheme.font-sm;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { clicked(); } }
}

// ── Section header ────────────────────────────────────────────────────────────

component SectionHeader inherits Rectangle {
    in property <string> title;
    in property <string> subtitle: "";
    height: subtitle == "" ? 40px : 56px;

    VerticalLayout {
        spacing: 3px;
        Text {
            text: title;
            color: HMTheme.text-primary;
            font-size: HMTheme.font-lg;
            font-weight: 700;
            letter-spacing: 0.3px;
        }
        if subtitle != "": Text {
            text: subtitle;
            color: HMTheme.text-muted;
            font-size: HMTheme.font-sm;
        }
    }
}

component Divider inherits Rectangle {
    height: 1px;
    background: HMTheme.border;
}

// ── Toggle row ────────────────────────────────────────────────────────────────

component ToggleRow inherits Rectangle {
    in property <string>  label;
    in property <string>  description: "";
    in-out property <bool> checked: false;
    callback toggled(bool);

    height: description == "" ? 48px : 60px;

    HorizontalLayout {
        alignment: start;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: label;
                color: HMTheme.text-primary;
                font-size: HMTheme.font-md;
                font-weight: 500;
            }
            if description != "": Text {
                text: description;
                color: HMTheme.text-muted;
                font-size: HMTheme.font-sm;
            }
        }

        // Toggle switch
        Rectangle {
            width: 44px;
            height: 24px;
            border-radius: 12px;
            background: checked
                ? @linear-gradient(90deg, HMTheme.orange, HMTheme.gold)
                : HMTheme.bg-elevated;
            border-width: 1px;
            border-color: checked ? HMTheme.gold : HMTheme.border;
            animate background { duration: HMTheme.anim-normal; }

            // Knob
            Rectangle {
                x: checked ? 22px : 2px;
                y: 2px;
                width: 18px; height: 18px;
                border-radius: 9px;
                background: checked ? HMTheme.bg-primary : HMTheme.text-muted;
                animate x { duration: HMTheme.anim-normal; easing: ease-out; }
            }

            TouchArea {
                clicked => {
                    checked = !checked;
                    toggled(checked);
                }
            }
        }
    }
}

// ── General section ───────────────────────────────────────────────────────────

component GeneralSection inherits VerticalLayout {
    spacing: HMTheme.space-md;
    callback language-changed(string);

    SectionHeader { title: "General"; subtitle: "Language, startup, and library options."; }
    Divider {}

    ToggleRow { label: "Auto-import on startup"; description: "Scan all sources when Hacker Mode starts."; checked: true; }
    ToggleRow { label: "Show playtime in library"; checked: true; }
    ToggleRow { label: "Enable notifications"; description: "Friend activity, downloads, store deals."; checked: true; }
    ToggleRow { label: "Start in fullscreen"; checked: true; }
}

// ── Appearance section ────────────────────────────────────────────────────────

component AppearanceSection inherits VerticalLayout {
    spacing: HMTheme.space-md;

    SectionHeader { title: "Appearance"; subtitle: "Theme colours, night mode, overlay."; }
    Divider {}

    ToggleRow { label: "Night Mode"; description: "Reduce blue light after sunset."; }
    ToggleRow { label: "Performance overlay in-game"; description: "Show CPU/GPU/FPS overlay on top of running games."; checked: true; }
    ToggleRow { label: "Animated backgrounds"; checked: false; }
}

// ── Compositor section ────────────────────────────────────────────────────────

component CompositorSection inherits VerticalLayout {
    spacing: HMTheme.space-md;
    callback vsync-toggled(bool);
    callback hdr-toggled(bool);
    callback adaptive-sync-toggled(bool);

    SectionHeader { title: "Compositor"; subtitle: "Display, rendering, and GPU settings."; }
    Divider {}

    ToggleRow {
        label: "VSync";
        description: "Eliminate screen tearing. May cap FPS to refresh rate.";
        checked: true;
        toggled(v) => { vsync-toggled(v); }
    }
    ToggleRow {
        label: "Adaptive Sync (FreeSync / G-Sync)";
        description: "Variable refresh rate for smoother gaming.";
        toggled(v) => { adaptive-sync-toggled(v); }
    }
    ToggleRow {
        label: "HDR";
        description: "High Dynamic Range output. Requires HDR display.";
        toggled(v) => { hdr-toggled(v); }
    }
    ToggleRow {
        label: "Xwayland";
        description: "Run Windows games via Proton and Wine (requires Xwayland).";
        checked: true;
    }

    // GPU info
    Rectangle {
        height: 56px;
        border-radius: HMTheme.radius-sm;
        background: HMTheme.bg-elevated;
        border-width: 1px;
        border-color: HMTheme.border;

        HorizontalLayout {
            padding: HMTheme.space-md;
            spacing: HMTheme.space-md;

            Text {
                text: "GPU";
                color: HMTheme.text-muted;
                font-size: HMTheme.font-xs;
                font-weight: 700;
                letter-spacing: 1px;
                vertical-alignment: center;
                width: 36px;
            }
            Text {
                text: "Auto-detected on startup";
                color: HMTheme.text-secondary;
                font-size: HMTheme.font-sm;
                vertical-alignment: center;
            }
        }
    }
}

// ── Proton section ────────────────────────────────────────────────────────────

component ProtonSection inherits VerticalLayout {
    spacing: HMTheme.space-md;
    callback default-changed(string);

    SectionHeader { title: "Proton / Wine"; subtitle: "Compatibility layer settings for Windows games."; }
    Divider {}

    ToggleRow {
        label: "Force Proton for all games";
        description: "Override native Linux games to also run through Proton.";
    }
    ToggleRow {
        label: "Enable DXVK";
        description: "DirectX to Vulkan translation layer (recommended).";
        checked: true;
    }
    ToggleRow {
        label: "Enable VKD3D-Proton";
        description: "DirectX 12 support via Vulkan.";
        checked: true;
    }
    ToggleRow {
        label: "Enable FSR (FidelityFX Super Resolution)";
        description: "Upscale games for better performance.";
    }

    // Install GE-Proton button
    Rectangle {
        height: 44px;
        width: btn-text.preferred-width + 40px;
        border-radius: HMTheme.radius-sm;
        background: HMTheme.bg-elevated;
        border-width: 1px;
        border-color: rgba(245,166,35,0.3);

        states [
            hover when ta.has-hover: { background: HMTheme.gold-glow; }
        ]
        animate background { duration: HMTheme.anim-fast; }

        btn-text := Text {
            text: "⬇  Install Latest GE-Proton";
            color: HMTheme.gold;
            font-size: HMTheme.font-sm;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        ta := TouchArea {}
    }
}

// ── About section ─────────────────────────────────────────────────────────────

component AboutSection inherits VerticalLayout {
    spacing: HMTheme.space-lg;

    SectionHeader { title: "About Hacker Mode"; }
    Divider {}

    Rectangle {
        height: 120px;
        border-radius: HMTheme.radius-md;
        background: HMTheme.bg-elevated;
        border-width: 1px;
        border-color: HMTheme.border;

        VerticalLayout {
            padding: HMTheme.space-lg;
            spacing: HMTheme.space-sm;
            alignment: center;

            HorizontalLayout {
                spacing: HMTheme.space-sm;
                alignment: start;
                Text { text: "⬡"; color: HMTheme.gold; font-size: 24px; vertical-alignment: center; }
                Text {
                    text: "HACKER MODE";
                    color: HMTheme.text-primary;
                    font-size: HMTheme.font-xl;
                    font-weight: 700;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }
            }

            Text { text: "Version 0.1.0 — HackerOS Gaming Environment"; color: HMTheme.text-muted; font-size: HMTheme.font-sm; }
            Text { text: "Built with Rust · Slint · Smithay · WRY"; color: HMTheme.text-muted; font-size: HMTheme.font-xs; letter-spacing: 0.5px; }
        }
    }
}
