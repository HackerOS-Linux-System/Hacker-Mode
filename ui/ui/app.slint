import { HMTheme }         from "theme.slint";
import { TopBar, TabItem } from "components/top_bar.slint";
import { BottomBar, RunningApp, PerfData } from "components/bottom_bar.slint";
import { Sidebar, SidebarSource, SidebarRunning } from "components/sidebar.slint";
import { HackerMenu, MenuStore, MenuDesktop } from "components/hacker_menu.slint";
import { LibraryScreen, HeroData, GameCardData } from "screens/library.slint";
import { StoreBrowserScreen, StoreTab } from "screens/store_browser.slint";

export { TabItem, RunningApp, PerfData, SidebarSource, SidebarRunning,
         HeroData, GameCardData, MenuStore, MenuDesktop, StoreTab }

export component AppWindow inherits Window {
    title: "HackerOS Hacker Mode";
    background: HMTheme.bg-primary;
    preferred-width:  1920px;
    preferred-height: 1080px;

    // ── State ─────────────────────────────────────────────────────────────
    in-out property <int>  active-tab:     0;   // 0=library 1=stores 2=downloads 3=community
    in-out property <int>  active-sidebar: 0;
    in-out property <int>  active-source: -1;
    in-out property <bool> hacker-menu-open: false;

    // Library data
    in property <HeroData>         hero;
    in property <[GameCardData]>   recent-games;
    in property <[GameCardData]>   all-games;
    in property <string>           library-filter: "";

    // Store browser data
    in property <[StoreTab]>  store-tabs;
    in-out property <int>     active-store: 0;
    in property <string>      store-url: "";
    in property <bool>        store-loading: false;
    in property <bool>        store-can-back: false;
    in property <bool>        store-can-forward: false;

    // Sidebar data
    in property <[SidebarSource]>  sidebar-sources;
    in property <[SidebarRunning]> sidebar-running;

    // Bottom bar data
    in property <[RunningApp]>  running-apps;
    in property <PerfData>      perf;
    in property <string>        clock-time: "00:00";

    // Top bar data
    in property <string> proton-version: "GE-Proton9-20";
    in property <string> user-initials:  "HM";

    // Hacker menu data
    in property <[MenuStore]>   menu-stores;
    in property <[MenuDesktop]> available-desktops;
    in property <bool>          night-mode-on: false;
    in property <string>        network-name: "";

    // ── Callbacks to Rust ────────────────────────────────────────────────
    callback play-game(string);
    callback open-game-detail(string);
    callback toggle-favourite(string);
    callback search-library(string);

    callback tab-changed(int);
    callback store-selected(int);
    callback store-navigate(string);
    callback store-back();
    callback store-forward();
    callback store-reload();
    callback store-login(string);

    callback open-store-browser(string);
    callback open-settings();
    callback toggle-night-mode();
    callback open-network();
    callback open-compositor-settings();
    callback power-action(string);
    callback switch-desktop(string);

    callback kill-running-app(string);
    callback run-app-dialog();

    // ── Layout ───────────────────────────────────────────────────────────
    VerticalLayout {
        spacing: 0px;

        // Top bar
        TopBar {
            active-tab: active-tab;
            proton-version: proton-version;
            user-initials: user-initials;
            tabs: [
                { label: "Library",   id: "library" },
                { label: "Stores",    id: "stores" },
                { label: "Downloads", id: "downloads" },
                { label: "Community", id: "community" },
            ];
            tab-changed(i) => {
                active-tab = i;
                tab-changed(i);
            }
            search-requested => { search-library(""); }
        }

        // Content row
        HorizontalLayout {
            vertical-stretch: 1;

            // Sidebar
            Sidebar {
                active-view:   active-sidebar;
                sources:       sidebar-sources;
                active-source: active-source;
                running:       sidebar-running;

                view-changed(i) => { active-sidebar = i; }
                source-selected(i) => { active-source = i; }
            }

            // Screen content
            if active-tab == 0: LibraryScreen {
                hero:          hero;
                recent-games:  recent-games;
                all-games:     all-games;
                filter-text:   library-filter;

                play(id)             => { play-game(id); }
                open-detail(id)      => { open-game-detail(id); }
                toggle-favourite(id) => { toggle-favourite(id); }
                search-changed(t)    => { search-library(t); }
                see-all-recent       => { active-sidebar = 1; }
                see-all-games        => { active-sidebar = 0; active-source = -1; }
            }

            if active-tab == 1: StoreBrowserScreen {
                stores:         store-tabs;
                active-store:   active-store;
                current-url:    store-url;
                loading:        store-loading;
                can-go-back:    store-can-back;
                can-go-forward: store-can-forward;

                store-selected(i)  => { active-store = i; store-selected(i); }
                navigate(url)      => { store-navigate(url); }
                go-back            => { store-back(); }
                go-forward         => { store-forward(); }
                reload             => { store-reload(); }
                login-store(id)    => { store-login(id); }
            }

            if active-tab == 2: DownloadsPlaceholder {}
            if active-tab == 3: CommunityPlaceholder {}
        }

        // Bottom bar
        BottomBar {
            running-apps: running-apps;
            perf:         perf;
            clock-time:   clock-time;

            hacker-menu-pressed => { hacker-menu-open = !hacker-menu-open; }
            run-app-pressed     => { run-app-dialog(); }
            desktop-pressed     => { switch-desktop(""); }
            app-clicked(id)     => { open-game-detail(id); }
            kill-app(id)        => { kill-running-app(id); }
        }
    }

    // ── Hacker Menu overlay ───────────────────────────────────────────────
    if hacker-menu-open: HackerMenu {
        stores:              menu-stores;
        available-desktops:  available-desktops;
        night-mode-on:       night-mode-on;
        network-name:        network-name;

        close               => { hacker-menu-open = false; }
        open-store(id)      => { hacker-menu-open = false; open-store-browser(id); }
        open-settings       => { hacker-menu-open = false; open-settings(); }
        toggle-night-mode   => { toggle-night-mode(); }
        open-network        => { hacker-menu-open = false; open-network(); }
        open-compositor-settings => { hacker-menu-open = false; open-compositor-settings(); }
        power-action(a)     => { hacker-menu-open = false; power-action(a); }
        switch-desktop(id)  => { hacker-menu-open = false; switch-desktop(id); }
    }
}

// ── Placeholder screens ───────────────────────────────────────────────────────

component DownloadsPlaceholder inherits Rectangle {
    background: HMTheme.bg-primary;
    horizontal-stretch: 1;

    Text {
        text: "Downloads";
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xl;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component CommunityPlaceholder inherits Rectangle {
    background: HMTheme.bg-primary;
    horizontal-stretch: 1;

    Text {
        text: "Community";
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xl;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
