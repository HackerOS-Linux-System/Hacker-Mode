export global HMTheme {
    // ── Backgrounds ──────────────────────────────────────────────────────────
    out property <color> bg-primary:   #0a0a08;
    out property <color> bg-secondary: #111110;
    out property <color> bg-elevated:  #181816;
    out property <color> bg-overlay:   #1e1e1b;

    // ── Brand / Accent ───────────────────────────────────────────────────────
    out property <color> gold:         #f5a623;
    out property <color> gold-dim:     #c47d0e;
    out property <color> gold-glow:    rgba(245, 166, 35, 0.12);
    out property <color> orange:       #e8580c;
    out property <color> orange-dim:   #b33f06;
    out property <color> orange-glow:  rgba(232, 88, 12, 0.12);

    // ── Text ─────────────────────────────────────────────────────────────────
    out property <color> text-primary:   #f0ede6;
    out property <color> text-secondary: #a09d96;
    out property <color> text-muted:     #6b6960;
    out property <color> text-disabled:  #3a3830;

    // ── Borders ──────────────────────────────────────────────────────────────
    out property <color> border:          #2a2a26;
    out property <color> border-focus:    rgba(245, 166, 35, 0.40);
    out property <color> border-active:   rgba(245, 166, 35, 0.60);

    // ── Status ───────────────────────────────────────────────────────────────
    out property <color> success:   #34d399;
    out property <color> warning:   #fbbf24;
    out property <color> error:     #f87171;
    out property <color> info:      #60a5fa;

    // ── Store source colours ─────────────────────────────────────────────────
    out property <color> steam-color:   #1a9fff;
    out property <color> epic-color:    #2d9cdb;
    out property <color> gog-color:     #8b5cf6;
    out property <color> amazon-color:  #ff9900;
    out property <color> itchio-color:  #fa5c5c;
    out property <color> lutris-color:  #f5a623;
    out property <color> native-color:  #34d399;

    // ── Spacing ──────────────────────────────────────────────────────────────
    out property <length> space-xs:  4px;
    out property <length> space-sm:  8px;
    out property <length> space-md:  16px;
    out property <length> space-lg:  24px;
    out property <length> space-xl:  40px;
    out property <length> space-2xl: 64px;

    // ── Radius ───────────────────────────────────────────────────────────────
    out property <length> radius-sm: 6px;
    out property <length> radius-md: 10px;
    out property <length> radius-lg: 16px;
    out property <length> radius-xl: 24px;

    // ── Typography ───────────────────────────────────────────────────────────
    out property <length> font-xs:  10px;
    out property <length> font-sm:  12px;
    out property <length> font-md:  14px;
    out property <length> font-lg:  18px;
    out property <length> font-xl:  24px;
    out property <length> font-2xl: 32px;
    out property <length> font-3xl: 48px;

    // ── Bar heights ───────────────────────────────────────────────────────────
    out property <length> topbar-height:    48px;
    out property <length> bottombar-height: 52px;
    out property <length> sidebar-width:    220px;

    // ── Animation durations ──────────────────────────────────────────────────
    out property <duration> anim-fast:   120ms;
    out property <duration> anim-normal: 200ms;
    out property <duration> anim-slow:   350ms;
}
