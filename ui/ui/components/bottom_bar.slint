import { HMTheme } from "../theme.slint";

export struct RunningApp {
    game-id: string,
    title: string,
    is-game: bool,
}

export struct PerfData {
    cpu-pct: float,
    gpu-pct: float,
    ram-used-mb: int,
    fps: int,
    gpu-temp: int,
    has-fps: bool,
    has-gpu: bool,
}

export component BottomBar inherits Rectangle {
    height: HMTheme.bottombar-height;
    background: HMTheme.bg-secondary;

    in property <[RunningApp]>  running-apps;
    in property <PerfData>      perf;
    in property <string>        clock-time: "00:00";

    callback hacker-menu-pressed();
    callback run-app-pressed();
    callback desktop-pressed();
    callback app-clicked(string);  // game-id
    callback kill-app(string);

    // Top border
    Rectangle {
        y: 0px;
        height: 1px;
        background: HMTheme.border;
    }

    HorizontalLayout {
        padding-left: HMTheme.space-md;
        padding-right: HMTheme.space-md;
        spacing: HMTheme.space-sm;
        alignment: start;

        // ── Hacker Menu button ────────────────────────────────────────────
        HackerMenuButton {
            clicked => { hacker-menu-pressed(); }
        }

        // ── Separator ─────────────────────────────────────────────────────
        BarSep {}

        // ── Quick actions ─────────────────────────────────────────────────
        QuickBtn {
            label: "▶ Run App";
            clicked => { run-app-pressed(); }
        }

        QuickBtn {
            label: "⊞ Desktop";
            clicked => { desktop-pressed(); }
        }

        // ── Running apps ──────────────────────────────────────────────────
        for app[i] in running-apps: RunningAppChip {
            title: app.title;
            is-game: app.is-game;
            clicked => { app-clicked(app.game-id); }
            kill => { kill-app(app.game-id); }
        }

        // ── Spacer ────────────────────────────────────────────────────────
        Rectangle { horizontal-stretch: 1; }

        // ── Perf pills ────────────────────────────────────────────────────
        HorizontalLayout {
            alignment: end;
            spacing: 6px;

            PerfPill {
                label: "CPU";
                value: Math.round(perf.cpu-pct);
                unit: "%";
                hot: perf.cpu-pct > 80.0;
            }

            if perf.has-gpu: PerfPill {
                label: "GPU";
                value: Math.round(perf.gpu-pct);
                unit: "%";
                hot: perf.gpu-pct > 85.0;
            }

            PerfPill {
                label: "RAM";
                value: perf.ram-used-mb / 1024;
                unit: "GB";
                hot: false;
            }

            if perf.has-fps: PerfPill {
                label: "FPS";
                value: perf.fps;
                unit: "";
                hot: perf.fps < 30;
                good: perf.fps >= 60;
            }
        }

        // ── Separator ─────────────────────────────────────────────────────
        BarSep {}

        // ── Clock ─────────────────────────────────────────────────────────
        Text {
            text: clock-time;
            color: HMTheme.gold;
            font-size: 20px;
            font-weight: 500;
            letter-spacing: 1px;
            vertical-alignment: center;
        }
    }
}

// ── Hacker Menu button ────────────────────────────────────────────────────────

component HackerMenuButton inherits Rectangle {
    callback clicked();

    height: 36px;
    width: self.preferred-width + 28px;
    border-radius: HMTheme.radius-sm;
    background: @linear-gradient(90deg, HMTheme.orange, HMTheme.gold);

    states [
        hover when ta.has-hover: { background: @linear-gradient(90deg, HMTheme.orange-dim, HMTheme.gold-dim); }
        pressed when ta.pressed: { background: @linear-gradient(90deg, HMTheme.orange-dim, HMTheme.gold-dim); }
    ]

    animate background { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 6px;
        alignment: center;

        Text {
            text: "⬡";
            color: HMTheme.bg-primary;
            font-size: 12px;
            vertical-alignment: center;
        }

        Text {
            text: "HACKER MENU";
            color: HMTheme.bg-primary;
            font-size: HMTheme.font-sm;
            font-weight: 700;
            letter-spacing: 1px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea { clicked => { clicked(); } }
}

// ── Quick action button ───────────────────────────────────────────────────────

component QuickBtn inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 36px;
    width: label-text.preferred-width + 24px;
    border-radius: HMTheme.radius-sm;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: HMTheme.border;

    states [
        hover when ta.has-hover: {
            border-color: rgba(245, 166, 35, 0.30);
            background: HMTheme.gold-glow;
            label-text.color: HMTheme.text-primary;
        }
    ]

    animate border-color, background { duration: HMTheme.anim-fast; }

    label-text := Text {
        text: label;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-sm;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: HMTheme.anim-fast; }
    }

    ta := TouchArea { clicked => { clicked(); } }
}

// ── Running app chip ──────────────────────────────────────────────────────────

component RunningAppChip inherits Rectangle {
    in property <string> title;
    in property <bool>   is-game: false;
    callback clicked();
    callback kill();

    height: 36px;
    width: clamp(chip-text.preferred-width + 40px, 80px, 200px);
    border-radius: HMTheme.radius-sm;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: is-game
        ? rgba(52, 211, 153, 0.25)
        : HMTheme.border;

    states [
        hover when ta.has-hover: {
            background: HMTheme.bg-overlay;
        }
    ]

    animate background { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        alignment: center;

        // Pulse dot for running games
        if is-game: Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: HMTheme.success;
        }

        chip-text := Text {
            text: title;
            color: is-game ? HMTheme.text-primary : HMTheme.text-secondary;
            font-size: HMTheme.font-sm;
            font-weight: 500;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { clicked(); }
        mouse-cursor: pointer;
    }
}

// ── Perf pill ─────────────────────────────────────────────────────────────────

component PerfPill inherits Rectangle {
    in property <string> label;
    in property <int>    value;
    in property <string> unit;
    in property <bool>   hot:  false;
    in property <bool>   good: false;

    height: 26px;
    width: pill-layout.preferred-width + 16px;
    border-radius: 13px;
    background: HMTheme.bg-elevated;
    border-width: 1px;
    border-color: hot  ? rgba(232, 88, 12,  0.30)
                : good ? rgba(52, 211, 153, 0.25)
                :        HMTheme.border;

    pill-layout := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 3px;
        alignment: center;

        Text {
            text: label;
            color: HMTheme.text-muted;
            font-size: HMTheme.font-xs;
            font-weight: 700;
            letter-spacing: 0.3px;
            vertical-alignment: center;
        }

        Text {
            text: value + unit;
            color: hot  ? HMTheme.orange
                 : good ? HMTheme.success
                 :        HMTheme.text-secondary;
            font-size: HMTheme.font-xs;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}

// ── Separator ─────────────────────────────────────────────────────────────────

component BarSep inherits Rectangle {
    width: 1px;
    height: 28px;
    background: HMTheme.border;
}
