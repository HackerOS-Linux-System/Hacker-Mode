import { HMTheme } from "../theme.slint";

export struct SidebarSource {
    id: string,
    label: string,
    count: int,
    color: color,
}

export struct SidebarRunning {
    game-id: string,
    title: string,
    playtime-h: int,
    playtime-m: int,
}

export component Sidebar inherits Rectangle {
    width: HMTheme.sidebar-width;
    background: HMTheme.bg-secondary;

    in property <int>                  active-view: 0;
    in property <[SidebarSource]>      sources;
    in property <int>                  active-source: -1;  // -1 = all
    in property <[SidebarRunning]>     running;

    callback view-changed(int);
    callback source-selected(int);  // index into sources, -1 = all

    // Right border
    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        background: HMTheme.border;
    }

    VerticalLayout {
        padding-top: HMTheme.space-md;
        padding-bottom: HMTheme.space-md;

        // ── View section ──────────────────────────────────────────────────
        SidebarSection { label: "VIEW"; }

        SidebarItem {
            icon: "⊞";
            label: "All Games";
            badge: "";
            active: active-view == 0 && active-source == -1;
            clicked => {
                view-changed(0);
                source-selected(-1);
            }
        }
        SidebarItem {
            icon: "▶";
            label: "Recently Played";
            badge: "";
            active: active-view == 1;
            clicked => { view-changed(1); }
        }
        SidebarItem {
            icon: "★";
            label: "Favourites";
            badge: "";
            active: active-view == 2;
            clicked => { view-changed(2); }
        }
        SidebarItem {
            icon: "⬇";
            label: "Downloads";
            badge: "";
            active: active-view == 3;
            clicked => { view-changed(3); }
        }

        // ── Sources section ───────────────────────────────────────────────
        SidebarSection { label: "SOURCES"; }

        for src[i] in sources: SidebarSourceItem {
            source: src;
            active: active-source == i;
            clicked => { source-selected(i); }
        }

        // ── Spacer ────────────────────────────────────────────────────────
        Rectangle { vertical-stretch: 1; }

        // ── Now running ───────────────────────────────────────────────────
        if running.length > 0: VerticalLayout {
            SidebarSection { label: "NOW PLAYING"; }

            for app in running: RunningEntry {
                title: app.title;
                hours: app.playtime-h;
                minutes: app.playtime-m;
            }
        }

        // ── Padding bottom ────────────────────────────────────────────────
        Rectangle { height: HMTheme.space-md; }
    }
}

// ── Section label ─────────────────────────────────────────────────────────────

component SidebarSection inherits Rectangle {
    in property <string> label;
    height: 28px;

    Text {
        x: HMTheme.space-md;
        text: label;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        font-weight: 700;
        letter-spacing: 1.5px;
        vertical-alignment: center;
    }
}

// ── Item ─────────────────────────────────────────────────────────────────────

component SidebarItem inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> badge;
    in property <bool>   active: false;
    callback clicked();

    height: 36px;
    margin-left: HMTheme.space-sm;
    margin-right: HMTheme.space-sm;
    border-radius: HMTheme.radius-sm;
    background: transparent;

    states [
        active when active: {
            background: rgba(245, 166, 35, 0.08);
            label-text.color: HMTheme.gold;
            icon-text.color: HMTheme.gold;
        }
        hover when ta.has-hover && !active: {
            background: HMTheme.bg-elevated;
            label-text.color: HMTheme.text-primary;
            icon-text.color: HMTheme.text-primary;
        }
    ]

    animate background { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: HMTheme.space-sm;
        padding-right: HMTheme.space-sm;
        spacing: HMTheme.space-sm;
        alignment: start;

        icon-text := Text {
            width: 20px;
            text: icon;
            color: HMTheme.text-muted;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
            animate color { duration: HMTheme.anim-fast; }
        }

        label-text := Text {
            text: label;
            color: HMTheme.text-muted;
            font-size: HMTheme.font-sm;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            animate color { duration: HMTheme.anim-fast; }
        }

        if badge != "": Rectangle {
            height: 18px;
            width: badge-text.preferred-width + 12px;
            border-radius: 9px;
            background: rgba(245, 166, 35, 0.12);

            badge-text := Text {
                text: badge;
                color: HMTheme.gold;
                font-size: HMTheme.font-xs;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea { clicked => { clicked(); } }
}

// ── Source item (with colour dot) ─────────────────────────────────────────────

component SidebarSourceItem inherits Rectangle {
    in property <SidebarSource> source;
    in property <bool>          active: false;
    callback clicked();

    height: 36px;
    margin-left: HMTheme.space-sm;
    margin-right: HMTheme.space-sm;
    border-radius: HMTheme.radius-sm;
    background: transparent;

    states [
        active when active: {
            background: rgba(245, 166, 35, 0.08);
            label-text.color: HMTheme.gold;
        }
        hover when ta.has-hover && !active: {
            background: HMTheme.bg-elevated;
            label-text.color: HMTheme.text-primary;
        }
    ]

    animate background { duration: HMTheme.anim-fast; }

    HorizontalLayout {
        padding-left: HMTheme.space-sm;
        padding-right: HMTheme.space-sm;
        spacing: HMTheme.space-sm;
        alignment: start;

        // Colour dot
        Rectangle {
            width: 7px;
            height: 7px;
            border-radius: 3.5px;
            background: source.color;
            y: (parent.height - self.height) / 2;
        }

        label-text := Text {
            text: source.label;
            color: HMTheme.text-muted;
            font-size: HMTheme.font-sm;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            animate color { duration: HMTheme.anim-fast; }
        }

        if source.count > 0: Rectangle {
            height: 18px;
            width: cnt-text.preferred-width + 12px;
            border-radius: 9px;
            background: rgba(245, 166, 35, 0.10);

            cnt-text := Text {
                text: source.count;
                color: HMTheme.gold;
                font-size: HMTheme.font-xs;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea { clicked => { clicked(); } }
}

// ── Running game entry ────────────────────────────────────────────────────────

component RunningEntry inherits Rectangle {
    in property <string> title;
    in property <int>    hours;
    in property <int>    minutes;

    height: 36px;
    margin-left: HMTheme.space-sm;
    margin-right: HMTheme.space-sm;
    border-radius: HMTheme.radius-sm;

    HorizontalLayout {
        padding-left: HMTheme.space-sm;
        padding-right: HMTheme.space-sm;
        spacing: HMTheme.space-sm;
        alignment: start;

        // Pulse dot
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: HMTheme.success;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: title;
            color: HMTheme.text-primary;
            font-size: HMTheme.font-xs;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        Text {
            text: hours > 0 ? hours + "h" : minutes + "m";
            color: HMTheme.text-muted;
            font-size: HMTheme.font-xs;
            vertical-alignment: center;
        }
    }
}
