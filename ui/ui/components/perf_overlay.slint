import { HMTheme } from "../theme.slint";
import { PerfData } from "../components/bottom_bar.slint";

export component PerfOverlay inherits Rectangle {
    in property <PerfData>  perf;
    in property <string>    corner: "top-right";  // "top-left"|"top-right"|"bottom-left"|"bottom-right"

    background: transparent;
    width: 100%; height: 100%;

    // Position the panel based on corner
    panel := Rectangle {
        x: corner == "top-left" || corner == "bottom-left"
            ? HMTheme.space-md
            : parent.width - self.width - HMTheme.space-md;
        y: corner == "top-left" || corner == "top-right"
            ? HMTheme.topbar-height + HMTheme.space-sm
            : parent.height - HMTheme.bottombar-height - self.height - HMTheme.space-sm;

        width: col.preferred-width + HMTheme.space-md * 2;
        height: col.preferred-height + HMTheme.space-md;
        border-radius: HMTheme.radius-sm;
        background: rgba(10, 10, 8, 0.85);
        border-width: 1px;
        border-color: rgba(245, 166, 35, 0.20);

        col := VerticalLayout {
            x: HMTheme.space-sm;
            y: HMTheme.space-xs;
            spacing: 3px;

            PerfRow { label: "CPU"; value: Math.round(perf.cpu-pct); unit: "%"; hot: perf.cpu-pct > 80.0; }
            if perf.has-gpu: PerfRow { label: "GPU"; value: Math.round(perf.gpu-pct); unit: "%"; hot: perf.gpu-pct > 85.0; }
            PerfRow { label: "RAM"; value: perf.ram-used-mb / 1024; unit: " GB"; hot: false; }
            if perf.has-fps: PerfRow {
                label: "FPS";
                value: perf.fps;
                unit: "";
                hot: perf.fps < 30;
                good: perf.fps >= 60;
            }
        }
    }
}

component PerfRow inherits HorizontalLayout {
    in property <string> label;
    in property <int>    value;
    in property <string> unit;
    in property <bool>   hot:  false;
    in property <bool>   good: false;

    spacing: HMTheme.space-sm;
    alignment: start;

    Text {
        width: 30px;
        text: label;
        color: HMTheme.text-muted;
        font-size: HMTheme.font-xs;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    Text {
        text: value + unit;
        color: hot  ? HMTheme.orange
             : good ? HMTheme.success
             :        HMTheme.text-secondary;
        font-size: HMTheme.font-xs;
        font-weight: 600;
        min-width: 40px;
    }
}
